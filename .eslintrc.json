{
  "env": {
    "node": true,
    "es2022": true,
    "jest": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:security/recommended-legacy"
  ],
  "plugins": ["security"],
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-console": ["warn", { "allow": ["error", "warn"] }],
    "no-unused-vars": "error",
    "strict": ["error", "global"],
    "security/detect-object-injection": "warn",
    "security/detect-non-literal-regexp": "warn"
  }
}
